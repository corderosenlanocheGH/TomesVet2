                  <% const currentType = typeConfigs.find((type) => type.key === activeTab) || typeConfigs[0]; %>
                  <% if (!currentType.records.length) { %>
                    <tr>
                      <td colspan="6" class="text-center text-muted py-4">Todavía no hay certificados cargados para este tipo.</td>
                    </tr>
                  <% } %>
                  <% currentType.records.forEach((certificado) => { %>
                    <tr>
                      <td>#<%= certificado.id %></td>
                      <td>
                        <div class="fw-semibold"><%= certificado.animal_nombre || certificado.mascota_nombre %></div>
                        <small class="text-muted"><%= certificado.animal_raza || '-' %></small>
                      </td>
                      <td><%= certificado.propietario_nombre %></td>
                      <td><%= summaryByType(currentType.key, certificado) %></td>
                      <td><%= dateByType(currentType.key, certificado) %></td>
                      <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" href="<%= pdfPathByType[currentType.key](certificado.id) %>" target="_blank" rel="noopener noreferrer">Generar PDF</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
