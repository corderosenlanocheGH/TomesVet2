<script>
  (() => {
    const forms = document.querySelectorAll('.js-cert-form');

    const fieldMap = {
      propietario: 'propietario',
      direccion: 'direccion',
      'animal-nombre': 'nombre',
      'animal-especie': 'especie',
      'animal-sexo': 'sexo',
      'animal-raza': 'raza',
      'animal-pelaje': 'pelaje',
      'animal-fecha-nacimiento': 'fechaNacimiento',
    };

    const syncFormData = (form) => {
      const mascotaSelect = form.querySelector('.js-cert-mascota');
      if (!mascotaSelect) return;
      const option = mascotaSelect.options[mascotaSelect.selectedIndex];
      if (!option || !option.value) return;

      Object.entries(fieldMap).forEach(([fieldName, datasetKey]) => {
        const input = form.querySelector(`[data-field="${fieldName}"]`);
        if (!input) return;
        input.value = option.dataset[datasetKey] || (fieldName === 'animal-especie' ? 'Canino' : '');
      });
    };

    forms.forEach((form) => {
      const mascotaSelect = form.querySelector('.js-cert-mascota');
      if (!mascotaSelect) return;
      mascotaSelect.addEventListener('change', () => syncFormData(form));
      if (mascotaSelect.value) {
        syncFormData(form);
      }

      form.addEventListener('reset', () => {
        window.requestAnimationFrame(() => {
          if (mascotaSelect.value) {
            syncFormData(form);
          }
        });
      });
    });

    const tabButtons = document.querySelectorAll('#certificados-tab button[data-bs-toggle="pill"]');
    tabButtons.forEach((button) => {
      button.addEventListener('shown.bs.tab', () => {
        const url = new URL(window.location.href);
        const paneId = button.getAttribute('data-bs-target') || '';
        const selectedType = paneId.replace('#pane-', '');
        if (selectedType) {
          if (url.searchParams.get('tipo') === selectedType) return;
          url.searchParams.set('tipo', selectedType);
          window.location.assign(url);
        }
      });
    });
  })();
</script>

