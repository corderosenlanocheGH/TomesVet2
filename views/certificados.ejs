<%- include('partials/head', { title: 'Certificados | TomesVet' }) %>
<%
  const activeTab = selectedCertificateType || 'leishmaniasis';
  const formatInputDate = (value = '') => {
    if (!value) return '';
    const normalized = value.toString().split('T')[0];
    if (/^\d{4}-\d{2}-\d{2}$/.test(normalized)) {
      return normalized;
    }
    const parsed = new Date(value);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.toISOString().slice(0, 10);
    }
    return '';
  };
  const formatShortDate = (value = '') => {
    if (!value) return '-';
    const normalized = value.toString().split('T')[0];
    const [year, month, day] = normalized.split('-');
    if (year && month && day) {
      return `${day}/${month}/${year}`;
    }
    const parsed = new Date(value);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.toLocaleDateString('es-AR');
    }
    return value;
  };
  const formatDateTime = (value = '') => {
    if (!value) return '-';
    const match = value.toString().match(/^(\d{4}-\d{2}-\d{2})[T\s](\d{2}:\d{2})/);
    if (match) {
      return `${formatShortDate(match[1])} ${match[2]}`;
    }
    return value;
  };
  const truncateText = (value = '', max = 70) => {
    if (!value) return '-';
    return value.length > max ? `${value.slice(0, max - 1)}…` : value;
  };
  const typeConfigs = [
    {
      key: 'leishmaniasis',
      label: 'Leishmaniasis',
      badgeClass: 'text-bg-success',
      description: 'Certificado con resultado diagnóstico y generación de PDF.',
      records: certificadosLeishmaniasis,
    },
    {
      key: 'tratamiento_antiparasitario',
      label: 'Tratamiento antiparasitario',
      badgeClass: 'text-bg-primary',
      description: 'Incluye antiparasitario interno, externo y observaciones.',
      records: certificadosTratamientosAntiparasitarios,
    },
    {
      key: 'implantacion_microchip_tatuaje',
      label: 'Implantación microchip / tatuaje',
      badgeClass: 'text-bg-info',
      description: 'Registra la implantación o tatuaje con región anatómica.',
      records: certificadosImplantacionMicrochip,
    },
    {
      key: 'lectura_microchip_tatuaje',
      label: 'Lectura microchip / tatuaje',
      badgeClass: 'text-bg-warning',
      description: 'Certifica la lectura actual del microchip o tatuaje.',
      records: certificadosLecturaMicrochip,
    },
    {
      key: 'libre_miasis',
      label: 'Libre de miasis',
      badgeClass: 'text-bg-secondary',
      description: 'Certificado sanitario con declaración de libre de miasis.',
      records: certificadosLibreMiasis,
    },
  ];
  const pdfPathByType = {
    leishmaniasis: (id) => `/certificados/leishmaniasis/${id}/pdf`,
    tratamiento_antiparasitario: (id) => `/certificados/tratamiento-antiparasitario/${id}/pdf`,
    implantacion_microchip_tatuaje: (id) => `/certificados/implantacion-microchip-tatuaje/${id}/pdf`,
    lectura_microchip_tatuaje: (id) => `/certificados/lectura-microchip-tatuaje/${id}/pdf`,
    libre_miasis: (id) => `/certificados/libre-miasis/${id}/pdf`,
  };
  const summaryByType = (type, certificado) => {
    switch (type) {
      case 'leishmaniasis':
        return certificado.resultado || 'Sin resultado';
      case 'tratamiento_antiparasitario':
        return `Interno: ${formatDateTime(certificado.interno_fecha_hora)} · Externo: ${formatDateTime(certificado.externo_fecha_hora)}`;
      case 'implantacion_microchip_tatuaje':
        return `Microchip: ${certificado.animal_microchip || '-'} · ${truncateText(certificado.lugar_implantacion || '', 36)}`;
      case 'lectura_microchip_tatuaje':
        return truncateText(certificado.detalle_lectura || 'Lectura certificada');
      case 'libre_miasis':
        return 'Animal declarado libre de miasis';
      default:
        return '-';
    }
  };
  const dateByType = (type, certificado) => {
    switch (type) {
      case 'leishmaniasis':
        return formatShortDate(certificado.fecha_resultado);
      case 'tratamiento_antiparasitario':
        return formatShortDate(certificado.created_at);
      case 'implantacion_microchip_tatuaje':
        return formatShortDate(certificado.fecha_implantacion);
      case 'lectura_microchip_tatuaje':
      case 'libre_miasis':
        return formatShortDate(certificado.created_at);
      default:
        return '-';
    }
  };
%>
<%- include('partials/nav') %>

<main class="content-area">
