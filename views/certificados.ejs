            <% typeConfigs.forEach((type) => { %>
              <button
                class="nav-link d-flex justify-content-between align-items-start text-start <%= activeTab === type.key ? 'active' : '' %>"
                id="tab-<%= type.key %>"
                data-bs-toggle="pill"
                data-bs-target="#pane-<%= type.key %>"
                type="button"
                role="tab"
                aria-controls="pane-<%= type.key %>"
                aria-selected="<%= activeTab === type.key ? 'true' : 'false' %>"
              >
                <span>
                  <span class="d-block fw-semibold"><%= type.label %></span>
                  <small class="d-block opacity-75"><%= type.description %></small>
                </span>
                <span class="badge rounded-pill <%= type.badgeClass %>"><%= type.records.length %></span>
              </button>
            <% }) %>
          </div>
        </div>
