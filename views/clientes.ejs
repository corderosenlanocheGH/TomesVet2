<%- include('partials/head', { title: 'Clientes | TomesVet' }) %>
<%- include('partials/nav') %>

<main class="container py-5">
  <div class="row g-4">
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h4 class="card-title mb-3">Nuevo cliente</h4>
          <form action="/clientes" method="POST" class="d-grid gap-3">
            <div>
              <label class="form-label">Nombre completo</label>
              <input class="form-control" type="text" name="nombre" required />
            </div>
            <div>
              <label class="form-label">Teléfono</label>
              <input class="form-control" type="text" name="telefono" required />
            </div>
            <div>
              <label class="form-label">Email</label>
              <input class="form-control" type="email" name="email" />
            </div>
            <div>
              <label class="form-label">Dirección</label>
              <input class="form-control" type="text" name="direccion" />
            </div>
            <button class="btn btn-primary" type="submit">Guardar</button>
          </form>
        </div>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h4 class="card-title mb-3">Clientes</h4>
          <div class="table-responsive">
            <table class="table align-middle">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Teléfono</th>
                  <th>Email</th>
                  <th>Dirección</th>
                  <th class="text-center">WhatsApp</th>
                </tr>
              </thead>
              <tbody>
                <% clientes.forEach((cliente) => { %>
                  <% const telefonoWhatsapp = (cliente.telefono || '').replace(/\D/g, ''); %>
                  <tr>
                    <td><%= cliente.nombre %></td>
                    <td><%= cliente.telefono %></td>
                    <td><%= cliente.email || '-' %></td>
                    <td><%= cliente.direccion || '-' %></td>
                    <td class="text-center">
                      <% if (telefonoWhatsapp) { %>
                        <a
                          href="https://wa.me/<%= telefonoWhatsapp %>"
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn btn-whatsapp-icon"
                          aria-label="Enviar WhatsApp a <%= cliente.nombre %>"
                          title="Enviar WhatsApp"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                            <path
                              d="M19.05 4.94A9.86 9.86 0 0 0 12.03 2 10 10 0 0 0 3.3 16.87L2 22l5.27-1.28a10 10 0 0 0 4.76 1.21h.01c5.52 0 10-4.48 10-10 0-2.67-1.05-5.18-2.99-6.99ZM12.04 20.2h-.01a8.3 8.3 0 0 1-4.22-1.15l-.3-.17-3.12.76.83-3.04-.2-.31a8.24 8.24 0 0 1-1.26-4.4c0-4.55 3.72-8.27 8.29-8.27 2.2 0 4.27.86 5.83 2.42a8.2 8.2 0 0 1 2.43 5.84c0 4.56-3.72 8.28-8.27 8.28Zm4.54-6.2c-.25-.13-1.47-.72-1.7-.8-.23-.08-.4-.13-.56.13-.16.25-.64.8-.78.96-.15.17-.29.19-.54.06-.25-.13-1.03-.38-1.97-1.2-.73-.65-1.23-1.44-1.37-1.68-.14-.25-.02-.38.11-.5.12-.12.25-.3.37-.45.12-.14.16-.25.25-.42.08-.17.04-.32-.02-.45-.06-.13-.56-1.34-.76-1.84-.2-.47-.41-.41-.56-.42h-.48c-.17 0-.45.06-.68.32-.23.25-.88.86-.88 2.1s.9 2.45 1.03 2.62c.13.17 1.77 2.7 4.29 3.78.6.26 1.08.41 1.44.53.61.2 1.16.17 1.6.1.49-.07 1.47-.6 1.67-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.29Z"
                            />
                          </svg>
                        </a>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
